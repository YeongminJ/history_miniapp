{
  "name": "history-king-noti-api",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "dev:scheduled": "wrangler dev --test-scheduled",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply history-king-noti-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply history-king-noti-db --remote"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.2.2",
    "drizzle-orm": "^0.30.10",
    "hono": "^4.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240605.0",
    "drizzle-kit": "^0.21.4",
    "typescript": "^5.4.5",
    "wrangler": "^3.60.0"
  }
}
